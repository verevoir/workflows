{
  "name": "@verevoir/workflows",
  "version": "0.6.0",
  "description": "Workflow-adapter primitive: a contract over kanban/issue/objective sources (cards with status, assignee, labels) with implementations as subpath imports. Trello today; Jira, Notion DBs, Linear, GitHub Issues, aigency objectives follow.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./trello": {
      "types": "./dist/trello/index.d.ts",
      "import": "./dist/trello/index.js"
    },
    "./notion": {
      "types": "./dist/notion/index.d.ts",
      "import": "./dist/notion/index.js"
    },
    "./obsidian": {
      "types": "./dist/obsidian/index.d.ts",
      "import": "./dist/obsidian/index.js"
    },
    "./backlog": {
      "types": "./dist/backlog/index.d.ts",
      "import": "./dist/backlog/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@notionhq/client": "*",
    "@verevoir/sources": "*",
    "yaml": "*"
  },
  "peerDependenciesMeta": {
    "@notionhq/client": {
      "optional": true
    },
    "@verevoir/sources": {
      "optional": true
    },
    "yaml": {
      "optional": true
    }
  },
  "devDependencies": {
    "@notionhq/client": "^5.22.0",
    "@types/node": "^25.8.0",
    "@verevoir/sources": "^0.6.0",
    "prettier": "^3",
    "typescript": "^5",
    "vitest": "^4",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "vite": "^8.0.16"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verevoir/workflows.git"
  },
  "engines": {
    "node": ">=20"
  }
}
